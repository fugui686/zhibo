            config = configparser.ConfigParser()
            config.read(CONFIG_FILE)
            if 'settings' in config:
                self.port_input.setText(config['settings'].get('port', ''))
                self.cookie_input.setText(config['settings'].get('cookie', ''))
                self.code_input.setText(config['settings'].get('code', ''))
                # 加载支付方式配置
                self.bobi_payment_input.setText(config['settings'].get('bobi_payment_id', ''))
                self.usdt_payment_input.setText(config['settings'].get('usdt_payment_id', ''))
                self.bobi_cash_input.setText(config['settings'].get('bobi_cash_id', '10150'))  # 新增：波币提现ID，默认10150

    def save_config(self):
        port = self.port_input.text().strip()
        cookie = self.cookie_input.text().strip()
        code = self.code_input.text().strip()
        bobi_payment = self.bobi_payment_input.text().strip()
        usdt_payment = self.usdt_payment_input.text().strip()
        bobi_cash = self.bobi_cash_input.text().strip()  # 新增：波币提现ID

        if not port or not cookie or not code or not bobi_payment or not usdt_payment or not bobi_cash:
            QMessageBox.warning(self, "提示",
                                "请完整填写所有配置项（端口、Cookie、登录码、波币支付ID、USDT支付ID、波币提现ID）后再保存。")
            return

        # 验证支付ID是否为数字
        try:
            int(bobi_payment)
            int(usdt_payment)
            int(bobi_cash)
        except ValueError:
            QMessageBox.warning(self, "提示", "所有支付ID必须是数字！")
            return

        config = configparser.ConfigParser()
        config['settings'] = {
            'port': port,
            'cookie': cookie,
            'code': code,
            'bobi_payment_id': bobi_payment,
            'usdt_payment_id': usdt_payment,
            'bobi_cash_id': bobi_cash  # 新增：波币提现ID
        }

        with open(CONFIG_FILE, 'w') as f:
            config.write(f)

        QMessageBox.information(self, "成功", "✅ 配置已保存")

