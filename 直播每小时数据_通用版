class WorkerThread(QThread):
    finished = pyqtSignal(str)

    def __init__(self, task_func):
        super().__init__()
        self.task_func = task_func

    def run(self):
        try:
            self.task_func()
            self.finished.emit("success")
        except requests.exceptions.ConnectionError as e:
            if "Max retries exceeded" in str(e) or "Failed to establish" in str(e):
                self.finished.emit("error: 连接服务器失败，请检查端口号是否正确或服务是否启动")
            else:
                self.finished.emit(f"error: 网络连接错误，请检查网络")
        except requests.exceptions.Timeout:
            self.finished.emit("error: 连接超时，请稍后重试")
        except requests.exceptions.RequestException as e:
            self.finished.emit(f"error: 网络请求异常")
        except Exception as e:
            error_str = str(e)
            # 处理HTTP响应中的业务错误
            if "login_code 校验失败" in error_str:
                self.finished.emit("error: login_code 校验失败，请检查登录码")
            elif "设备登陆中" in error_str:
                self.finished.emit("error: 设备登陆中，请检查Cookie是否有效")
            elif "Max retries exceeded" in error_str or "Failed to establish" in error_str:
                self.finished.emit("error: 连接服务器失败，请检查端口号")
            else:
                # 其他未知错误，只显示前50个字符避免窗口撑宽
                short_error = error_str[:50] + "..." if len(error_str) > 50 else error_str
                self.finished.emit(f"error: {short_error}")


